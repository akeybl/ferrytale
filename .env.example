# Copy this file to .env and fill in local values.
# .env is gitignored; this template is safe to commit.

# Required for Gemini API calls.
GEMINI_API_KEY=

# Recommended for default OmniVoice character voices; required for first-time
# ElevenLabs Voice Design calls.
ELEVENLABS_API_KEY=

# Optional: use Gemini priority service tier by default.
# IF_ENGINE_FAST_MODE=1

# Optional: point voice mode at a custom whisper.cpp checkout. By default,
# scripts/install --voice prepares .cache/whisper.cpp inside this repo.
# IF_ENGINE_WHISPER_DIR=/absolute/path/to/whisper.cpp
# IF_ENGINE_WHISPER_CLI=/absolute/path/to/whisper-cli
# IF_ENGINE_WHISPER_MODEL=/absolute/path/to/ggml-large-v3-turbo-q5_0.bin
# IF_ENGINE_WHISPER_VAD_MODEL=/absolute/path/to/ggml-silero-v6.2.0.bin

# Optional: TTS selection and OmniVoice tuning. ./play --no-voice skips all voice
# dependencies; ./play --kokoro (or IF_ENGINE_TTS_ENGINE=kokoro before the first
# ./play bootstrap) selects the lighter Kokoro engine and skips OmniVoice-specific
# Python dependencies.
# IF_ENGINE_TTS_ENGINE=omnivoice
# IF_ENGINE_TTS_ENGINE=kokoro
# IF_ENGINE_OMNIVOICE_SPEED=0.9
# IF_ENGINE_OMNIVOICE_INSTRUCT=male, low pitch, elderly, british accent
# IF_ENGINE_OMNIVOICE_WHISPER_TAGS=1
# IF_ENGINE_OMNIVOICE_CHARACTER_VOICES=1
# IF_ENGINE_OMNIVOICE_CHARACTER_VOICES=0  # OmniVoice without ElevenLabs voices
# IF_ENGINE_ELEVENLABS_VOICE_CACHE_DIR=/absolute/path/to/elevenlabs-voices-cache

# Optional: override the bundled audio. Each is a WAV file — point the env var at
# your own clip, or just replace the file in assets/. IF_ENGINE_NARRATOR_VOICE is
# cloned by OmniVoice; set it empty to use a text description (OMNIVOICE_INSTRUCT).
# IF_ENGINE_NARRATOR_VOICE=/absolute/path/to/narrator.wav
# IF_ENGINE_CONFIRM_CUE=/absolute/path/to/confirm-cue.wav
# IF_ENGINE_TURN_CUE=/absolute/path/to/turn-cue.wav

# Optional: Kokoro voice name (only when the Kokoro engine is active). This sets the
# VOICE, not on/off — use ./play --no-voice to disable voice.
# IF_ENGINE_KOKORO_VOICE=bm_george

# Optional: pick audio input/output devices by name or index. List devices with:
#   .venv/bin/python diagnostics/voice_diagnose.py --list-devices
# IF_ENGINE_VOICE_INPUT_DEVICE=
# IF_ENGINE_VOICE_OUTPUT_DEVICE=

# Optional: wake-word defaults. CLI flags such as --wake-word and --car-mode
# are usually clearer for one-off runs.
# IF_ENGINE_WAKE_WORD=1
# IF_ENGINE_CAR_MODE=1
# IF_ENGINE_WAKE_WORD_THRESHOLD=0.9
# IF_ENGINE_CAR_WAKE_WORD_THRESHOLD=0.4
# IF_ENGINE_WAKE_WORD_PREPROCESS=1
